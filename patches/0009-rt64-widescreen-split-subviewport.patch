+// Split-screen widescreen quadrant tag (Automobili Lamborghini port). A value >= NONE so
+// movedFromOrigin() leaves the viewport translate untouched; both the FOV gate
+// (rt64_projection_processor) and the NDC-scale gate (rt64_framebuffer_renderer) treat a
+// perspective viewport carrying it as "render wide" even though it only covers a fraction
+// of the framebuffer width -- so a 3P/4P quadrant fills its output quarter instead of being
+// squeezed to the 4:3 centre.
+#define G_EX_ORIGIN_WIDE            0xC00
 
 #define G_EX_NOPUSH                 0x0
 #define G_EX_PUSH                   0x1
