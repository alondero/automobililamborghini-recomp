+// ---- LAMBO_THREAD_TRACE diagnostic (RETAINED scheduler tool, default-OFF): track per-thread message
+// activity. Records, per OSThread id: successful recv/send counts and the queue ptr it is currently
+// blocked on; lambo_thread_trace_dump() (called from main.cpp's vi_cb) prints a periodic snapshot so we
+// can SEE which thread's recv-count freezes and on which queue. This was the diagnostic that root-caused
+// the state-6 audio-worker monopoly (W97); it is KEPT, not deleted, because it is the reliable
+// cooperative-scheduler probe for the still-open boot frontier (#64 demo-race / state 7->8 -- see #64
+// "Method notes"). Default-off (one cached static-int branch when disabled). RETIRE when #64 closes.
+namespace {
+    bool lambo_ttrace_on() {
+        static int v = -1;
+        if (v < 0) { const char* e = std::getenv("LAMBO_THREAD_TRACE"); v = (e && e[0] && e[0] != '0') ? 1 : 0; }
+        return v;
+    }
+    struct LamboThreadInfo {
+        std::atomic<uint64_t> recv_ok{0};
+        std::atomic<uint64_t> send_ok{0};
+        std::atomic<uint32_t> blocked_recv_q{0};
+        std::atomic<uint32_t> blocked_send_q{0};
+    };
+    LamboThreadInfo g_lambo_tinfo[64];
+    int lambo_cur_tid(uint8_t* rdram) {
+        PTR(OSThread) self = ultramodern::this_thread();
+        if (self == NULLPTR) return 63; // non-game / unknown
+        int id = TO_PTR(OSThread, self)->id;
+        if (id < 0 || id >= 63) return 63;
+        return id;
+    }
+}
+
+extern "C" void lambo_thread_trace_dump(int vi) {
+    if (!lambo_ttrace_on()) return;
+    char buf[1024];
+    int n = std::snprintf(buf, sizeof(buf), "[ttrace] vi=%d", vi);
+    for (int i = 0; i < 64 && n < (int)sizeof(buf) - 64; i++) {
+        LamboThreadInfo& t = g_lambo_tinfo[i];
+        uint64_t r = t.recv_ok.load(), s = t.send_ok.load();
+        uint32_t br = t.blocked_recv_q.load(), bs = t.blocked_send_q.load();
+        if (r || s || br || bs) {
+            n += std::snprintf(buf + n, sizeof(buf) - n, " t%d{r=%llu s=%llu br=%X bs=%X}",
+                               i, (unsigned long long)r, (unsigned long long)s, br, bs);
+        }
+    }
+    std::fprintf(stderr, "%s\n", buf);
+}
