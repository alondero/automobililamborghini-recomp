# `scripts/gen_syms_toml.py` + the N64Recomp CLI produce these from the ROM.
RecompiledFuncs/
data_dump.toml
# RSP audio microcode, RSPRecomp'd from your ROM (BUILDING.md step 3):
src/aspMain.cpp

