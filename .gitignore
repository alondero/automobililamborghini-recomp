build/
build-*/
out/
CMakeUserPresets.json
compile_commands.json

# --- Editor / OS -----------------------------------------------------------
.vs/
.vscode/
.idea/
.DS_Store
Thumbs.db

# --- Bundled emulator + debug captures (not source; regenerable/large) ------
